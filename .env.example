# ===== 阿里云 DashScope（通义）=====
# 用于 Embedding、ChatTongyi、Rerank
# 在控制台创建 API Key：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# ===== MySQL 数据库 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=rag_system

# ===== Redis 缓存 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== JWT 配置 =====
JWT_SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
