# ===== 阿里云 DashScope（通义）=====
# 用于 Embedding、ChatTongyi、Rerank
# 在控制台创建 API Key：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# ===== MySQL 数据库 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=rag_system

# ===== Redis 缓存 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Agent 配置 =====
# 后端模式：custom=混合架构（默认），legacy=create_agent
AGENT_BACKEND=custom
# 对话摘要触发轮数（≥此轮数时自动压缩历史）
AGENT_SUMMARY_TRIGGER_ROUNDS=6
AGENT_SUMMARY_KEEP_RECENT=6
AGENT_SUMMARY_MIN_INTERVAL_ROUNDS=3

# ===== 联网搜索（Tavily）=====
# 可选，不需要联网搜索可不填
# 在 https://tavily.com/ 注册获取
TAVILY_API_KEY=
WEB_SEARCH_ENABLED=true

# ===== JWT 配置 =====
JWT_SECRET_KEY=change-me-to-a-random-secret-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
